{
  "$schema": "../gen/schemas/remote-schema.json",
  "identifier": "remote-universal",
  "description": "Allow any remote frontend URL to access all Tauri IPC commands. The desktop app loads its frontend from a configurable server URL (dev, staging, prod) so all origins must be permitted.",
  "remote": {
    "urls": ["http://*", "http://*:*", "https://*", "https://*:*"]
  },
  "permissions": [
    "core:default",
    "fs:allow-read",
    "fs:allow-write",
    "fs:allow-exists",
    "fs:allow-mkdir",
    "fs:allow-read-dir",
    "fs:allow-remove",
    "notification:default",
    "notification:allow-is-permission-granted",
    "notification:allow-request-permission",
    "notification:allow-notify",
    "clipboard-manager:allow-read-text",
    "clipboard-manager:allow-write-text",
    "clipboard-manager:allow-read-image",
    "clipboard-manager:allow-write-image",
    "clipboard-manager:allow-write-html",
    "clipboard-manager:allow-clear",
    "opener:default",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "dialog:allow-message",
    "dialog:allow-ask",
    "dialog:allow-confirm",
    "updater:default"
  ]
}
